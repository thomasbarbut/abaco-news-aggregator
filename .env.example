# ============================================================
# ABACO News Aggregation Platform — Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to git
# ============================================================

# ---------------------
# Application
# ---------------------
DEBUG=false
DOMAIN=news.abaco.ro

# ---------------------
# Database (PostgreSQL)
# ---------------------
POSTGRES_USER=abaco
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=abaco_news
DATABASE_URL=postgresql+asyncpg://abaco:change_me_strong_password@postgres:5432/abaco_news

# ---------------------
# Redis
# ---------------------
REDIS_URL=redis://redis:6379/0

# ---------------------
# JWT Security
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
# ---------------------
JWT_SECRET=change_me_generate_a_64_byte_hex_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------------------
# Microsoft Entra ID (Azure AD)
# Register app at: https://portal.azure.com → Azure Active Directory → App registrations
# Redirect URI to add: https://news.abaco.ro/api/auth/callback
# Required API permissions: User.Read (delegated)
# ---------------------
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=your-azure-tenant-id
MICROSOFT_REDIRECT_URI=https://news.abaco.ro/api/auth/callback

# ---------------------
# Email Notifications (SMTP)
# Used for sync failure alerts to thomas.barbut@abaco.ro
# ---------------------
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=notifications@abaco.ro
SMTP_PASSWORD=your-smtp-password
ALERT_EMAIL=thomas.barbut@abaco.ro

# ---------------------
# Sync Engine
# ---------------------
SYNC_INTERVAL_MINUTES=15
